#!/usr/bin/env bash
# pmemtester - Parallel wrapper for memtester
# Version: 0.7
# Author: Johnathon Weare <jrweare@gmail.com>
# URL: https://github.com/widefox/pmemtester
# SPDX-License-Identifier: GPL-2.0-only

set -euo pipefail

# shellcheck disable=SC2034
pmemtester_version="0.7"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
for lib in "${SCRIPT_DIR}"/lib/*.sh; do
    source "$lib"
done

# run_single_node_test: run the full test pipeline for a single NUMA node
# Writes exit code to <node_log_dir>/result file
# Usage: run_single_node_test <node> <memtester_path> <stressapptest_path> <run_stressapptest_pass> <ram_kb> <node_log_dir>
# Reads globals: ITERATIONS, THREADS, PIN, STOP_ON_ERROR, STRESSAPPTEST_MODE, STRESSAPPTEST_SECONDS,
#                ESTIMATE_MODE, ALLOW_CE
run_single_node_test() {
    local node="$1" memtester_path="$2" stressapptest_path="$3" run_stressapptest_pass="$4"
    local ram_kb="$5" node_log_dir="$6"

    # Resolve CPUs for this node (own or borrowed from donor)
    local node_info core_count cpu_source_node
    node_info="$(resolve_node_cpus "$node")"
    local prefix="${node_info%% *}"
    local rest="${node_info#* }"
    core_count="${rest%% *}"
    local cpu_list_str="${rest#* }"
    cpu_source_node="${prefix#*:}"

    if [[ "$prefix" == donor:* ]]; then
        echo "Node ${node}: CPU-less node, borrowing CPUs from node ${cpu_source_node}"
    fi

    # Thread override per node
    if [[ "$THREADS" -gt 0 ]]; then
        core_count="$THREADS"
    fi

    # CPU pinning
    local node_cpu_list=()
    if [[ "$PIN" -eq 1 ]]; then
        read -ra node_cpu_list <<< "$cpu_list_str"
        if [[ "$THREADS" -eq 0 ]]; then
            core_count="${#node_cpu_list[@]}"
        fi
    fi

    local ram_per_core_mb
    ram_per_core_mb="$(divide_ram_per_core_mb "$ram_kb" "$core_count")"

    local size_arg
    size_arg="$(mb_to_memtester_arg "$ram_per_core_mb")"

    init_logs "$node_log_dir" "$core_count"

    echo "Node ${node}: ${ram_per_core_mb}MB x ${core_count} cores"

    # Determine the numactl node: membind to target, cpunodebind to cpu_source_node
    local effective_numa="$node"

    # Phase 1: memtester (use per-node NUMA_NODE and CPU_LIST)
    NUMA_NODE="$effective_numa" CPU_LIST=("${node_cpu_list[@]}")
    run_all_memtesters "$memtester_path" "$size_arg" "$ITERATIONS" "$core_count" "$node_log_dir"
    local memtester_result=0
    wait_and_collect "$node_log_dir" "$STOP_ON_ERROR" || memtester_result=1

    aggregate_logs "$node_log_dir" "$core_count"

    # Phase 2: stressapptest (per-node)
    local stressapptest_result=0
    if [[ "$run_stressapptest_pass" -eq 1 ]] && [[ "$memtester_result" -eq 0 ]]; then
        local total_mb=$(( ram_per_core_mb * core_count ))
        local sat_seconds="$STRESSAPPTEST_SECONDS"
        if [[ "$sat_seconds" -eq 0 ]]; then
            sat_seconds=1
        fi
        local sat_cpu_csv=""
        if [[ "${#node_cpu_list[@]}" -gt 0 ]]; then
            sat_cpu_csv="$(IFS=,; echo "${node_cpu_list[*]}")"
        fi
        run_stressapptest "$stressapptest_path" "$sat_seconds" "$total_mb" "$node_log_dir" \
            "$sat_cpu_csv" "$effective_numa" || stressapptest_result=1
    fi

    # Write result
    local result=0
    if [[ "$memtester_result" -ne 0 ]] || [[ "$stressapptest_result" -ne 0 ]]; then
        result=1
    fi
    echo "$result" > "${node_log_dir}/result"
    return "$result"
}

# run_multi_node: orchestrate parallel per-node test runs
# Usage: run_multi_node <memtester_path> <stressapptest_path> <run_stressapptest_pass> <ram_kb> <log_dir>
run_multi_node() {
    local memtester_path="$1" stressapptest_path="$2" run_stressapptest_pass="$3"
    local ram_kb="$4" log_dir="$5"

    local nodes_str
    nodes_str="$(parse_numa_nodes "$NUMA_NODE")"
    local nodes=()
    read -ra nodes <<< "$nodes_str"
    local num_nodes="${#nodes[@]}"

    # Divide RAM equally among nodes
    local ram_per_node_kb=$(( ram_kb / num_nodes ))

    print_status "Multi-node NUMA: testing ${num_nodes} nodes (${nodes[*]})" "$log_dir"

    # EDAC warning for multi-node
    local edac_supported=0
    if check_edac_supported 2>/dev/null; then
        edac_supported=1
        print_status "WARNING: EDAC errors cannot be attributed to individual NUMA nodes" "$log_dir"
        capture_edac_messages > "${log_dir}/edac_messages_before.txt"
        capture_edac_counters > "${log_dir}/edac_counters_before.txt"
    fi

    # Launch per-node tests in parallel
    local node_pids=()
    local node
    for node in "${nodes[@]}"; do
        local node_log_dir="${log_dir}/node_${node}"
        mkdir -p "$node_log_dir"
        run_single_node_test "$node" "$memtester_path" "$stressapptest_path" \
            "$run_stressapptest_pass" "$ram_per_node_kb" "$node_log_dir" &
        node_pids+=($!)
    done

    # Wait for all nodes and collect results
    local overall_result=0
    local i=0
    for node in "${nodes[@]}"; do
        local node_log_dir="${log_dir}/node_${node}"
        if wait "${node_pids[$i]}" 2>/dev/null; then
            print_status "Node ${node}: PASS" "$log_dir"
        else
            print_status "Node ${node}: FAIL" "$log_dir"
            overall_result=1
        fi
        i=$(( i + 1 ))
    done

    # EDAC after (single snapshot spanning all nodes)
    if [[ "$edac_supported" -eq 1 ]]; then
        capture_edac_messages > "${log_dir}/edac_messages_after.txt"
        capture_edac_counters > "${log_dir}/edac_counters_after.txt"
        local edac_class
        edac_class="$(classify_edac_counters "${log_dir}/edac_counters_before.txt" "${log_dir}/edac_counters_after.txt" 2>/dev/null)" || true
        if [[ "$edac_class" != "none" ]]; then
            print_status "EDAC: ${edac_class} (cannot attribute to specific node)" "$log_dir"
            overall_result=1
        fi
    fi

    # Overall verdict
    if [[ "$overall_result" -eq 0 ]]; then
        color_pass
    else
        color_fail "multi-node"
    fi
    return "$overall_result"
}

main() {
    parse_args "$@"
    color_init

    # --check-deps: diagnostic report and exit (before validate_args)
    if [[ "$CHECK_DEPS" -eq 1 ]]; then
        check_deps
        return $?
    fi

    validate_args

    local memtester_path
    memtester_path="$(find_memtester "$MEMTESTER_DIR")"
    validate_memtester "$memtester_path"

    # Resolve stressapptest binary based on mode
    local stressapptest_path=""
    local run_stressapptest_pass=0
    case "$STRESSAPPTEST_MODE" in
        on)
            stressapptest_path="$(find_stressapptest "$STRESSAPPTEST_DIR")"
            validate_stressapptest "$stressapptest_path"
            run_stressapptest_pass=1
            ;;
        auto)
            if stressapptest_path="$(find_stressapptest "$STRESSAPPTEST_DIR" 2>/dev/null)"; then
                run_stressapptest_pass=1
            fi
            ;;
        off)
            run_stressapptest_pass=0
            ;;
    esac

    local ram_kb
    if [[ -n "${SIZE:-}" ]]; then
        ram_kb="$(parse_size_to_kb "$SIZE")"
    else
        local millipercent
        millipercent="$(decimal_to_millipercent "$PERCENT")"
        ram_kb="$(calculate_test_ram_kb_milli "$millipercent" "$RAM_TYPE")"
    fi

    # Multi-node NUMA: dispatch to run_multi_node
    if [[ -n "${NUMA_NODE:-}" ]] && [[ "$NUMA_NODE" == *,* ]]; then
        local log_dir="${LOG_DIR:-/tmp/pmemtester.$$}"
        init_logs "$log_dir" 0
        check_memlock_sufficient "$ram_kb" || configure_memlock "$ram_kb"
        run_multi_node "$memtester_path" "$stressapptest_path" "$run_stressapptest_pass" \
            "$ram_kb" "$log_dir"
        return $?
    fi

    local core_count ram_per_core_mb
    core_count="$(get_core_count)"

    # NUMA node handling: override core count with node's physical cores
    if [[ -n "${NUMA_NODE:-}" ]]; then
        local node_cores
        node_cores="$(get_node_core_count "$NUMA_NODE")"
        if [[ "$node_cores" -eq 0 ]]; then
            echo "ERROR: NUMA node ${NUMA_NODE} has no CPUs. For CPU-less NUMA nodes (e.g., HBM), use: numactl --membind=${NUMA_NODE} pmemtester [OPTIONS]" >&2
            return 1
        fi
        core_count="$node_cores"
    fi

    # Thread override (integrates with NUMA)
    local threads_override_msg=""
    if [[ "$THREADS" -gt 0 ]]; then
        threads_override_msg="Thread override: using --threads ${THREADS} (auto-detected: ${core_count} cores)"
        if [[ -n "${NUMA_NODE:-}" ]] && [[ "$THREADS" -gt "$core_count" ]]; then
            echo "WARNING: --threads ${THREADS} exceeds NUMA node ${NUMA_NODE} core count (${core_count})" >&2
        fi
        core_count="$THREADS"
    fi

    # CPU pinning: populate CPU_LIST for per-thread taskset wrapping
    if [[ "$PIN" -eq 1 ]]; then
        local cpu_list_str
        cpu_list_str="$(get_physical_cpu_list "${NUMA_NODE:-}")"
        read -ra CPU_LIST <<< "$cpu_list_str"
        # If --threads not set, use pinned CPU count as core_count
        if [[ "$THREADS" -eq 0 ]]; then
            core_count="${#CPU_LIST[@]}"
        fi
    fi

    ram_per_core_mb="$(divide_ram_per_core_mb "$ram_kb" "$core_count")"
    validate_ram_params "$core_count" "$ram_per_core_mb"

    local size_arg
    size_arg="$(mb_to_memtester_arg "$ram_per_core_mb")"

    check_memlock_sufficient "$ram_kb" || configure_memlock "$ram_kb"

    local log_dir="${LOG_DIR:-/tmp/pmemtester.$$}"
    init_logs "$log_dir" "$core_count"
    if [[ -n "$threads_override_msg" ]]; then
        print_status "$threads_override_msg" "$log_dir"
    fi
    # Report NUMA and pinning info
    if [[ -n "${NUMA_NODE:-}" ]]; then
        print_status "NUMA node: ${NUMA_NODE}" "$log_dir"
    fi
    if [[ "$PIN" -eq 1 ]]; then
        print_status "CPU pinning: enabled (CPUs: ${CPU_LIST[*]})" "$log_dir"
    fi

    # Report binary detection
    print_status "memtester found: ${memtester_path}" "$log_dir"
    if [[ "$run_stressapptest_pass" -eq 1 ]]; then
        print_status "stressapptest found: ${stressapptest_path}" "$log_dir"
    elif [[ "$STRESSAPPTEST_MODE" != "off" ]]; then
        print_status "stressapptest not found (Phase 2 will be skipped)" "$log_dir"
    fi

    # Time estimation (calibration)
    if [[ "$ESTIMATE_MODE" != "off" ]]; then
        # Adaptive calibration size: 4x L3 cache (STREAM rule) to escape cache
        local l3_kb calibration_mb
        if l3_kb="$(get_l3_cache_kb)"; then
            calibration_mb=$(( l3_kb * 4 / 1024 ))
        else
            calibration_mb=512
        fi
        if [[ "$calibration_mb" -gt "$ram_per_core_mb" ]]; then
            calibration_mb="$ram_per_core_mb"
        fi
        if [[ "$calibration_mb" -lt 1 ]]; then
            calibration_mb=1
        fi

        local cal_secs=0
        local cal_ok=0
        if cal_secs="$(run_calibration "$memtester_path" "$log_dir" "$calibration_mb")"; then
            cal_ok=1
        fi
        if [[ "$cal_ok" -eq 1 ]]; then
            local est_secs
            est_secs="$(estimate_duration "$cal_secs" "$calibration_mb" "$ram_per_core_mb" "$ITERATIONS")"
            print_phase_estimate "Phase 1" "$est_secs" "$log_dir"
        elif [[ "$ESTIMATE_MODE" == "on" ]]; then
            print_status "WARNING: calibration failed, time estimate unavailable" "$log_dir"
        fi
    fi

    local total_mb=$(( ram_per_core_mb * core_count ))
    local run_start_seconds=$SECONDS
    print_status "pmemtester started: ${total_mb}MB across ${core_count} cores, ${ITERATIONS} iteration(s)" "$log_dir"

    # EDAC before
    local edac_supported=0
    if check_edac_supported 2>/dev/null; then
        edac_supported=1
        capture_edac_messages > "${log_dir}/edac_messages_before.txt"
        capture_edac_counters > "${log_dir}/edac_counters_before.txt"
    fi

    # Phase 1: memtester
    print_status "Phase 1 (memtester) started: ${ram_per_core_mb}MB x ${core_count} instances" "$log_dir"
    local phase1_start=$SECONDS

    # EDAC polling for --stop-on-error
    local edac_sentinel="${log_dir}/edac_poll_sentinel"
    local edac_poll_pid=""
    if [[ "$STOP_ON_ERROR" -eq 1 ]] && [[ "$edac_supported" -eq 1 ]]; then
        poll_edac_for_ue "${log_dir}/edac_counters_before.txt" "$edac_sentinel" 10 &
        edac_poll_pid=$!
    fi

    run_all_memtesters "$memtester_path" "$size_arg" "$ITERATIONS" "$core_count" "$log_dir"
    local memtester_result=0
    wait_and_collect "$log_dir" "$STOP_ON_ERROR" || memtester_result=1

    # Stop EDAC poll loop
    if [[ -n "$edac_poll_pid" ]]; then
        echo "stop" > "$edac_sentinel"
        wait "$edac_poll_pid" 2>/dev/null || true
    fi

    # Check if EDAC poll triggered early stop
    local edac_early_stop=0
    if [[ -f "$edac_sentinel" ]] && [[ "$(cat "$edac_sentinel")" == "ue" ]]; then
        edac_early_stop=1
        STOP_ON_ERROR_TRIGGERED="edac_ue"
        log_master "Early stop triggered by EDAC UE detected during Phase 1" "$log_dir"
        # Kill any remaining memtester processes
        kill_all_memtesters "$log_dir"
    fi

    local phase1_elapsed=$(( SECONDS - phase1_start ))
    print_status "Phase 1 (memtester) finished: $(format_phase_result "$core_count" "$MEMTESTER_FAIL_COUNT") ($(format_duration "$phase1_elapsed"))" "$log_dir"

    # Log early stop trigger if applicable
    if [[ -n "$STOP_ON_ERROR_TRIGGERED" ]]; then
        print_status "Early stop triggered by: ${STOP_ON_ERROR_TRIGGERED}" "$log_dir"
    fi

    # Intermediate EDAC check (informational)
    local edac_mid_class="none"
    if [[ "$edac_supported" -eq 1 ]]; then
        capture_edac_messages > "${log_dir}/edac_messages_mid.txt"
        capture_edac_counters > "${log_dir}/edac_counters_mid.txt"
        edac_mid_class="$(classify_edac_counters "${log_dir}/edac_counters_before.txt" "${log_dir}/edac_counters_mid.txt" 2>/dev/null)" || true
        print_status "EDAC after Phase 1: $(format_edac_summary "$edac_mid_class")" "$log_dir"
    fi

    # Phase 2: conditional stressapptest
    local stressapptest_result=0
    local early_stop=$(( edac_early_stop || (STOP_ON_ERROR == 1 && memtester_result != 0) ))
    if [[ "$run_stressapptest_pass" -eq 1 ]] && [[ "$early_stop" -eq 0 ]]; then
        # auto mode: skip if memtester failed
        if [[ "$STRESSAPPTEST_MODE" == "auto" ]] && [[ "$memtester_result" -ne 0 ]]; then
            log_master "Skipping stressapptest: memtester failed" "$log_dir"
        else
            # Determine duration
            local sat_seconds="$STRESSAPPTEST_SECONDS"
            if [[ "$sat_seconds" -eq 0 ]]; then
                sat_seconds="$phase1_elapsed"
                if [[ "$sat_seconds" -lt 1 ]]; then
                    sat_seconds=1
                fi
            fi
            print_status "Phase 2 (stressapptest) started: ${total_mb}MB, ${sat_seconds}s" "$log_dir"
            print_phase_estimate "Phase 2" "$sat_seconds" "$log_dir"
            local phase2_start=$SECONDS
            # Build CPU list CSV for stressapptest pinning
            local sat_cpu_csv=""
            if [[ "${#CPU_LIST[@]}" -gt 0 ]]; then
                sat_cpu_csv="$(IFS=,; echo "${CPU_LIST[*]}")"
            fi
            run_stressapptest "$stressapptest_path" "$sat_seconds" "$total_mb" "$log_dir" \
                "$sat_cpu_csv" "${NUMA_NODE:-}" || stressapptest_result=1
            local phase2_elapsed=$(( SECONDS - phase2_start ))
            if [[ "$stressapptest_result" -eq 0 ]]; then
                print_status "Phase 2 (stressapptest) finished: PASSED ($(format_duration "$phase2_elapsed"))" "$log_dir"
            else
                print_status "Phase 2 (stressapptest) finished: FAILED ($(format_duration "$phase2_elapsed"))" "$log_dir"
            fi
        fi
    fi

    # EDAC after (spans both phases for final verdict)
    local edac_msg_result=0
    local edac_class="none"
    if [[ "$edac_supported" -eq 1 ]]; then
        capture_edac_messages > "${log_dir}/edac_messages_after.txt"
        capture_edac_counters > "${log_dir}/edac_counters_after.txt"
        compare_edac_messages "${log_dir}/edac_messages_before.txt" "${log_dir}/edac_messages_after.txt" || edac_msg_result=1
        edac_class="$(classify_edac_counters "${log_dir}/edac_counters_before.txt" "${log_dir}/edac_counters_after.txt" 2>"${log_dir}/edac_detail.txt")" || true
        if [[ "$edac_class" != "none" ]]; then
            log_master "EDAC counter classification: ${edac_class}" "$log_dir"
            cat "${log_dir}/edac_detail.txt" >> "${log_dir}/master.log"
        fi
    fi

    aggregate_logs "$log_dir" "$core_count"

    local total_elapsed=$(( SECONDS - run_start_seconds ))
    print_status "Total duration: $(format_duration "$total_elapsed")" "$log_dir"

    # Final verdict
    # Build failure source for diagnostic output
    local fail_sources=""
    if [[ "$memtester_result" -ne 0 ]]; then
        fail_sources="memtester"
    fi
    if [[ "$stressapptest_result" -ne 0 ]]; then
        fail_sources="${fail_sources:+${fail_sources}, }stressapptest"
    fi
    if [[ "$edac_class" == "ue_only" ]] || [[ "$edac_class" == "ce_and_ue" ]]; then
        fail_sources="${fail_sources:+${fail_sources}, }EDAC: ${edac_class}"
    fi
    if [[ "$edac_msg_result" -ne 0 ]]; then
        fail_sources="${fail_sources:+${fail_sources}, }EDAC: new messages"
    fi

    # Priority 1: any failure → FAIL
    if [[ -n "$fail_sources" ]]; then
        log_master "FAIL: memtester_result=${memtester_result} stressapptest_result=${stressapptest_result} edac_class=${edac_class} edac_msg_result=${edac_msg_result}" "$log_dir"
        color_fail "$fail_sources"
        return 1
    fi
    # Priority 2: CE only + --allow-ce → PASS with WARNING
    if [[ "$edac_class" == "ce_only" ]] && [[ "$ALLOW_CE" -eq 1 ]]; then
        log_master "PASS (WARNING: correctable EDAC errors detected)" "$log_dir"
        color_pass
        color_warn "correctable EDAC errors detected (ce_only)"
        return 0
    fi
    # Priority 3: CE only without --allow-ce → FAIL
    if [[ "$edac_class" == "ce_only" ]]; then
        log_master "FAIL: memtester_result=${memtester_result} edac_class=${edac_class}" "$log_dir"
        color_fail "EDAC: ce_only"
        return 1
    fi
    # Priority 4: clean → PASS
    log_master "PASS: All tests passed, no EDAC errors" "$log_dir"
    color_pass
    return 0
}

main "$@"
